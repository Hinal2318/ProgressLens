# ========================
# ProgressLens — .gitignore
# ========================

# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment Variables (NEVER commit secrets) ──────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ── Production Builds ─────────────────────────────────────
dist/
build/
frontend/dist/
frontend/build/

# ── Uploaded Files (user-generated content) ──────────────
backend/uploads/

# ── Logs ─────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / Editor Artifacts ─────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml

# ── Testing & Coverage ───────────────────────────────────
coverage/
*.lcov
.nyc_output

# ── Vite Cache ───────────────────────────────────────────
.vite/
vite.config.js.timestamp-*

# ── Misc ─────────────────────────────────────────────────
.cache/
.temp/
*.tmp
*.swp
*.swo
